// ═══════════════════════════════════════════════════════════════
// ArenaMatchMaker — PvP 匹配系统
// ═══════════════════════════════════════════════════════════════

export class ArenaMatchMaker {
  /** 当前对手列表 */
  private opponents: ArenaOpponent[] = [];
  /** 上次免费刷新时间戳 */
  private lastFreeRefreshTime: number = 0;
  /** 今日已刷新次数 */
  private dailyRefreshUsed: number = 0;
  /** 上次日重置时间 */
  private lastDailyResetTime: number = 0;

  /**
   * 选择 5 个对手
   *
   * 战力范围：玩家战力 × 0.7 ~ × 1.3
   * 段位范围：玩家段位 ± 3 级
   *
   * @param playerPower 玩家战力
   * @param playerRank 玩家段位等级
   * @returns 5 个对手信息
   */
  selectOpponents(playerPower: number, playerRank: number): ArenaOpponent[] {
    this.checkDailyReset();
    this.opponents = this.generateOpponents(playerPower, playerRank, 5);
    return [...this.opponents];
  }

  /**
   * 刷新对手列表
   *
   * 免费刷新：距离上次免费刷新 ≥ 30 分钟
   * 手动刷新：消耗 500 铜钱，每日最多 10 次
   *
   * @param costGold 消耗的铜钱数（手动刷新时传入）
   * @returns 是否刷新成功
   */
  refreshOpponents(costGold: number = 0): boolean {
    this.checkDailyReset();

    const now = Date.now();
    const isFreeRefresh = (now - this.lastFreeRefreshTime) >= FREE_REFRESH_INTERVAL;

    if (isFreeRefresh) {
      this.lastFreeRefreshTime = now;
      return true;
    }

    // 手动刷新
    if (this.dailyRefreshUsed >= DAILY_REFRESH_MAX) {
      return false;
    }

    if (costGold < MANUAL_REFRESH_COST) {
      return false;
    }

    this.dailyRefreshUsed++;
    return true;
  }

  /**
   * 获取挑战信息
   *
   * @returns 每日挑战使用情况、免费刷新剩余时间等
   */
  getChallengeInfo(): { dailyUsed: number; dailyMax: number; freeRefreshTime: number } {
    this.checkDailyReset();
    const now = Date.now();
    const elapsed = now - this.lastFreeRefreshTime;
    const remaining = Math.max(0, FREE_REFRESH_INTERVAL - elapsed);

    return {
      dailyUsed: this.dailyRefreshUsed,
      dailyMax: DAILY_REFRESH_MAX,
      freeRefreshTime: remaining,
    };
  }

  /**
   * 获取当前对手列表
   */
  getCurrentOpponents(): ArenaOpponent[] {
    return [...this.opponents];
  }

  // ───────────────────────────────────────────────────────────
  // 私有方法
  // ───────────────────────────────────────────────────────────

  /** 检查并执行每日重置 */
  private checkDailyReset(): void {
    const now = Date.now();
    const today = new Date(now).setHours(0, 0, 0, 0);
    if (this.lastDailyResetTime < today) {
      this.dailyRefreshUsed = 0;
      this.lastDailyResetTime = today;
    }
  }

  /** 生成 AI 对手 */
  private generateOpponents(playerPower: number, playerRank: number, count: number): ArenaOpponent[] {
    const opponents: ArenaOpponent[] = [];
    const usedNames = new Set<string>();

    for (let i = 0; i < count; i++) {
      // 战力浮动 ×0.7 ~ ×1.3
      const powerMult = 0.7 + Math.random() * 0.6;
      const power = Math.floor(playerPower * powerMult);

      // 段位浮动 ±3
      const rankOffset = Math.floor(Math.random() * 7) - 3;
      const rank = Math.max(1, Math.min(24, playerRank + rankOffset));

      // 随机选择不重复的名称
      let name: string;
      do {
        name = AI_OPPONENT_NAMES[Math.floor(Math.random() * AI_OPPONENT_NAMES.length)];
      } while (usedNames.has(name) && usedNames.size < AI_OPPONENT_NAMES.length);
      usedNames.add(name);

      // 生成阵容
      const team = this.generateAITeam(power);
      const strategy = AI_STRATEGIES[Math.floor(Math.random() * AI_STRATEGIES.length)];

      opponents.push({
        id: `ai_arena_${Date.now()}_${i}`,
        name,
        power,
        rank,
        team,
        defenseStrategy: strategy,
      });
    }

    // 按战力排序（从弱到强）
    opponents.sort((a, b) => a.power - b.power);
    return opponents;
  }

  /** 生成 AI 武将阵容 */
  private generateAITeam(power: number): GeneralInfo[] {
    const teamSize = 3 + Math.floor(Math.random() * 2); // 3~4 人
    const team: GeneralInfo[] = [];
    const avgPower = Math.floor(power / teamSize);

    for (let i = 0; i < teamSize; i++) {
      const rarityIdx = Math.min(
        AI_RARITIES.length - 1,
        Math.floor(avgPower / 500)
      );
      team.push({
        id: `gen_ai_${i}`,
        name: AI_OPPONENT_NAMES[Math.floor(Math.random() * AI_OPPONENT_NAMES.length)],
        level: Math.max(1, Math.floor(avgPower / 100)),
        rarity: AI_RARITIES[rarityIdx],
        position: i < Math.ceil(teamSize / 2) ? 'front' : 'back',
      });
    }

    return team;
  }

  // ───────────────────────────────────────────────────────────
  // 序列化
  // ───────────────────────────────────────────────────────────

  serialize(): { opponents: ArenaOpponent[]; lastFreeRefreshTime: number; dailyRefreshUsed: number; lastDailyResetTime: number } {
    return {
      opponents: this.opponents,
      lastFreeRefreshTime: this.lastFreeRefreshTime,
      dailyRefreshUsed: this.dailyRefreshUsed,
      lastDailyResetTime: this.lastDailyResetTime,
    };
  }

  deserialize(data: Record<string, unknown>): void {
    if (Array.isArray(data.opponents)) {
      this.opponents = data.opponents as ArenaOpponent[];
    }
    if (typeof data.lastFreeRefreshTime === 'number') {
      this.lastFreeRefreshTime = data.lastFreeRefreshTime;
    }
    if (typeof data.dailyRefreshUsed === 'number') {
      this.dailyRefreshUsed = data.dailyRefreshUsed;
    }
    if (typeof data.lastDailyResetTime === 'number') {
      this.lastDailyResetTime = data.lastDailyResetTime;
    }
  }
}

// ═══════════════════════════════════════════════════════════════
// ArenaBattle — PvP 战斗
// ═══════════════════════════════════════════════════════════════

export class ArenaBattle {
  /**
   * 执行 PvP 战斗
   *
   * 回合制战斗，最多 10 回合。
   * 防守方享有 +10% 全属性加成。
   * 超时判定：10 回合后若双方均未全灭，剩余 HP 百分比高者获胜。
   *
   * @param attacker 攻方队伍
   * @param defender 守方队伍
   * @returns 战斗结果
   */
  executeBattle(attacker: BattleTeam, defender: BattleTeam): ArenaBattleResult {
    // 深拷贝武将数据，避免修改原始数据
    const atkGenerals = this.cloneGenerals(attacker.generals);
    const defGenerals = this.cloneGenerals(defender.generals);

    // 防守方加成 +10%
    for (const g of defGenerals) {
      g.maxHp = Math.floor(g.maxHp * (1 + DEFENSE_BONUS_RATIO));
      g.hp = g.maxHp;
      g.attack = Math.floor(g.attack * (1 + DEFENSE_BONUS_RATIO));
      g.defense = Math.floor(g.defense * (1 + DEFENSE_BONUS_RATIO));
    }

    const replay: BattleRound[] = [];
    const atkMaxHp = atkGenerals.reduce((s, g) => s + g.maxHp, 0);
    const defMaxHp = defGenerals.reduce((s, g) => s + g.maxHp, 0);

    for (let round = 1; round <= MAX_BATTLE_ROUNDS; round++) {
      const actions: BattleAction[] = [];

      // 按速度排序，决定行动顺序
      const allGenerals = [
        ...atkGenerals.filter(g => g.isAlive).map(g => ({ ...g, side: 'attacker' as const })),
        ...defGenerals.filter(g => g.isAlive).map(g => ({ ...g, side: 'defender' as const })),
      ].sort((a, b) => b.speed - a.speed);

      for (const actor of allGenerals) {
        // 重新获取引用（因为 HP 会变化）
        const actorRef = actor.side === 'attacker'
          ? atkGenerals.find(g => g.id === actor.id)!
          : defGenerals.find(g => g.id === actor.id)!;

        if (!actorRef.isAlive) continue;

        // 选择目标：攻击对方存活武将中 HP 最低的
        const enemies = actor.side === 'attacker'
          ? defGenerals.filter(g => g.isAlive)
          : atkGenerals.filter(g => g.isAlive);

        if (enemies.length === 0) break;

        const target = enemies.reduce((min, g) => g.hp < min.hp ? g : min, enemies[0]);

        // 选择技能：优先使用可用技能，否则普攻
        const skill = this.selectSkill(actorRef);

        // 计算伤害
        const damage = this.calculateDamage(actorRef, target, skill);

        // 应用伤害
        target.hp = Math.max(0, target.hp - damage);
        if (target.hp <= 0) {
          target.isAlive = false;
        }

        // 减少冷却
        for (const s of actorRef.skills) {
          if (s.currentCooldown > 0) s.currentCooldown--;
        }
        if (skill.currentCooldown === 0) {
          skill.currentCooldown = skill.cooldown;
        }

        actions.push({
          actor: actorRef.name,
          side: actor.side,
          skill: skill.name,
          target: target.name,
          value: damage,
          type: skill.type,
        });
      }

      const atkHp = atkGenerals.reduce((s, g) => s + (g.isAlive ? g.hp : 0), 0);
      const defHp = defGenerals.reduce((s, g) => s + (g.isAlive ? g.hp : 0), 0);

      replay.push({
        round,
        actions,
        attackerHp: atkHp,
        defenderHp: defHp,
      });

      // 检查胜负
      const atkAlive = atkGenerals.some(g => g.isAlive);
      const defAlive = defGenerals.some(g => g.isAlive);

      if (!atkAlive || !defAlive) break;
    }

    // 判定胜负
    const atkAlive = atkGenerals.some(g => g.isAlive);
    const defAlive = defGenerals.some(g => g.isAlive);

    let victory: boolean;
    if (atkAlive && !defAlive) {
      victory = true;
    } else if (!atkAlive && defAlive) {
      victory = false;
    } else {
      // 超时判定：比较剩余 HP 百分比
      const atkHpPercent = atkGenerals.reduce((s, g) => s + g.hp, 0) / atkMaxHp;
      const defHpPercent = defGenerals.reduce((s, g) => s + g.hp, 0) / defMaxHp;
      victory = atkHpPercent > defHpPercent;
    }

    // 计算积分变化
    const pointsChange = this.calculatePointsChange(victory, attacker.totalPower, defender.totalPower);

    // 计算竞技币奖励
    const arenaCoins = victory ? WIN_ARENA_COINS : LOSE_ARENA_COINS;

    return {
      victory,
      pointsChange,
      arenaCoins,
      rounds: replay.length,
      replay,
    };
  }

  // ───────────────────────────────────────────────────────────
  // 私有方法
  // ───────────────────────────────────────────────────────────

  /** 深拷贝武将列表 */
  private cloneGenerals(generals: BattleGeneral[]): BattleGeneral[] {
    return generals.map(g => ({
      ...g,
      skills: g.skills.map(s => ({ ...s })),
    }));
  }

  /** 选择技能 */
  private selectSkill(general: BattleGeneral): BattleSkill {
    // 优先使用冷却完毕且非普攻的技能
    const available = general.skills.filter(s => s.currentCooldown === 0);
    if (available.length > 0) {
      // 选择倍率最高的技能
      return available.reduce((best, s) => s.multiplier > best.multiplier ? s : best, available[0]);
    }
    // 默认普攻
    return { id: 'normal_attack', name: '普攻', multiplier: 1.0, cooldown: 0, currentCooldown: 0, type: 'damage' };
  }

  /** 计算伤害 */
  private calculateDamage(attacker: BattleGeneral, defender: BattleGeneral, skill: BattleSkill): number {
    // 基础伤害 = 攻击力 × 技能倍率 - 防御力 × 0.5
    const baseDamage = attacker.attack * skill.multiplier - defender.defense * 0.5;
    // 浮动 ±10%
    const variance = 0.9 + Math.random() * 0.2;
    // 最低伤害 = 攻击力 × 10%
    const minDamage = attacker.attack * 0.1;
    return Math.max(minDamage, Math.floor(baseDamage * variance));
  }

  /** 计算积分变化 */
  private calculatePointsChange(victory: boolean, attackerPower: number, defenderPower: number): number {
    if (victory) {
      // 以弱胜强获得更多积分
      const powerRatio = defenderPower / Math.max(1, attackerPower);
      const bonus = Math.floor((powerRatio - 1) * 20);
      const base = WIN_POINTS_MIN + Math.floor(Math.random() * (WIN_POINTS_MAX - WIN_POINTS_MIN + 1));
      return base + Math.max(0, bonus);
    } else {
      // 以强负弱扣除更多积分
      const powerRatio = attackerPower / Math.max(1, defenderPower);
      const penalty = Math.floor((powerRatio - 1) * 10);
      const base = LOSE_POINTS_MIN + Math.floor(Math.random() * (LOSE_POINTS_MAX - LOSE_POINTS_MIN + 1));
      return -(base + Math.max(0, penalty));
    }
  }
}

// ═══════════════════════════════════════════════════════════════
// ArenaRanking — 段位与赛季
// ═══════════════════════════════════════════════════════════════

export class ArenaRanking {
  /** 当前积分 */
  private points: number = 0;
  /** 赛季编号 */
  private seasonNumber: number = 1;
  /** 赛季开始时间戳 */
  private seasonStartTime: number = Date.now();
  /** 历史最高段位 */
  private highestRank: number = 1;
  /** 赛季胜场 */
  private seasonWins: number = 0;
  /** 赛季负场 */
  private seasonLosses: number = 0;

  /**
   * 获取段位信息
   *
   * @returns 当前段位、积分、赛季天数等
   */
  getRankInfo(): { tier: string; division: number; points: number; seasonDays: number; tierIcon: string; level: number } {
    const tierDef = this.getTierByPoints(this.points);
    const seasonElapsed = Date.now() - this.seasonStartTime;
    const seasonDays = Math.floor(seasonElapsed / (24 * 60 * 60 * 1000));

    return {
      tier: tierDef.tier,
      division: tierDef.division,
      points: this.points,
      seasonDays,
      tierIcon: tierDef.icon,
      level: tierDef.level,
    };
  }

  /**
   * 获取赛季奖励
   *
   * 根据当前段位等级匹配奖励表。
   *
   * @returns 奖励列表
   */
  getSeasonRewards(): Reward[] {
    const tierDef = this.getTierByPoints(this.points);

    // 从高到低匹配奖励
    for (let i = SEASON_REWARD_TABLE.length - 1; i >= 0; i--) {
      if (tierDef.level >= SEASON_REWARD_TABLE[i].minLevel) {
        return [...SEASON_REWARD_TABLE[i].rewards];
      }
    }

    return [];
  }

  /**
   * 更新积分
   *
   * @param pointsChange 积分变化值（正为增加，负为减少）
   */
  updatePoints(pointsChange: number): void {
    this.points = Math.max(0, this.points + pointsChange);

    // 更新历史最高段位
    const currentRank = this.getTierByPoints(this.points).level;
    if (currentRank > this.highestRank) {
      this.highestRank = currentRank;
    }
  }

  /**
   * 记录胜负
   */
  recordResult(victory: boolean): void {
    if (victory) {
      this.seasonWins++;
    } else {
      this.seasonLosses++;
    }
  }

  /**
   * 检查赛季是否结束
   *
   * 赛季 28 天周期，到期后积分重置。
   *
   * @returns 是否赛季已结束
   */
  checkSeasonEnd(): boolean {
    const elapsed = Date.now() - this.seasonStartTime;
    const seasonMs = SEASON_DAYS * 24 * 60 * 60 * 1000;
    return elapsed >= seasonMs;
  }

  /**
   * 开始新赛季
   *
   * 积分重置规则：保留 50%，最低 100 分。
   */
  startNewSeason(): void {
    // 积分重置
    this.points = Math.max(SEASON_MIN_POINTS, Math.floor(this.points * SEASON_RESET_RATIO));
    this.seasonNumber++;
    this.seasonStartTime = Date.now();
    this.seasonWins = 0;
    this.seasonLosses = 0;
  }

  /**
   * 获取当前积分
   */
  getPoints(): number {
    return this.points;
  }

  /**
   * 获取赛季统计
   */
  getSeasonStats(): { seasonNumber: number; wins: number; losses: number; winRate: number; highestRank: number } {
    const total = this.seasonWins + this.seasonLosses;
    return {
      seasonNumber: this.seasonNumber,
      wins: this.seasonWins,
      losses: this.seasonLosses,
      winRate: total > 0 ? Math.round((this.seasonWins / total) * 100) : 0,
      highestRank: this.highestRank,
    };
  }

  /**
   * 获取所有段位定义
   */
  static getAllTiers(): ArenaTierDef[] {
    return [...ARENA_TIERS];
  }

  // ───────────────────────────────────────────────────────────
  // 私有方法
  // ───────────────────────────────────────────────────────────

  /** 根据积分获取段位定义 */
  private getTierByPoints(points: number): ArenaTierDef {
    for (let i = ARENA_TIERS.length - 1; i >= 0; i--) {
      if (points >= ARENA_TIERS[i].minPoints) {
        return ARENA_TIERS[i];
      }
    }
    return ARENA_TIERS[0];
  }

  // ───────────────────────────────────────────────────────────
  // 序列化
  // ───────────────────────────────────────────────────────────

  serialize(): { points: number; seasonNumber: number; seasonStartTime: number; highestRank: number; seasonWins: number; seasonLosses: number } {
    return {
      points: this.points,
      seasonNumber: this.seasonNumber,
      seasonStartTime: this.seasonStartTime,
      highestRank: this.highestRank,
      seasonWins: this.seasonWins,
      seasonLosses: this.seasonLosses,
    };
  }

  deserialize(data: Record<string, unknown>): void {
    if (typeof data.points === 'number') this.points = data.points;
    if (typeof data.seasonNumber === 'number') this.seasonNumber = data.seasonNumber;
    if (typeof data.seasonStartTime === 'number') this.seasonStartTime = data.seasonStartTime;
    if (typeof data.highestRank === 'number') this.highestRank = data.highestRank;
    if (typeof data.seasonWins === 'number') this.seasonWins = data.seasonWins;
    if (typeof data.seasonLosses === 'number') this.seasonLosses = data.seasonLosses;
  }
}

// ═══════════════════════════════════════════════════════════════
// ArenaDefense — 防守阵容
// ═══════════════════════════════════════════════════════════════

export class ArenaDefense {
  /** 防守阵容 */
  private defenseTeam: BattleTeam | null = null;
  /** 防守策略 */
  private defenseStrategy: DefenseStrategy = 'balanced';
  /** 防守日志 */
  private defenseLog: DefenseRecord[] = [];

  /**
   * 设置防守阵容
   *
   * @param team 防守队伍
   */
  setDefenseTeam(team: BattleTeam): void {
    this.defenseTeam = {
      ...team,
      generals: team.generals.map(g => ({ ...g, skills: [...g.skills] })),
    };
  }

  /**
   * 获取防守策略
   *
   * 根据阵容配置自动分析最优策略：
   * - balanced：均衡配置（前排坦克 + 后排输出）
   * - aggressive：全输出阵容
   * - defensive：全坦克/治疗阵容
   * - tactical：控制/减益为主
   *
   * @returns 防守策略类型
   */
  getDefenseStrategy(): DefenseStrategy {
    if (this.defenseStrategy !== 'balanced' || !this.defenseTeam) {
      return this.defenseStrategy;
    }

    // 自动分析阵容并推荐策略
    return this.analyzeTeamStrategy(this.defenseTeam);
  }

  /**
   * 手动设置防守策略
   */
  setDefenseStrategy(strategy: DefenseStrategy): void {
    this.defenseStrategy = strategy;
  }

  /**
   * 获取防守日志
   *
   * @returns 被挑战记录列表（按时间倒序）
   */
  getDefenseLog(): DefenseRecord[] {
    return [...this.defenseLog].sort((a, b) => b.timestamp - a.timestamp);
  }

  /**
   * 获取防守胜率统计
   */
  getDefenseStats(): { total: number; wins: number; losses: number; winRate: number } {
    const total = this.defenseLog.length;
    const wins = this.defenseLog.filter(r => r.result === 'win').length;
    const losses = total - wins;
    return {
      total,
      wins,
      losses,
      winRate: total > 0 ? Math.round((wins / total) * 100) : 0,
    };
  }

  /**
   * 记录一次防守结果
   */
  recordDefense(record: DefenseRecord): void {
    this.defenseLog.push(record);
    // 最多保留 100 条记录
    if (this.defenseLog.length > 100) {
      this.defenseLog = this.defenseLog.slice(-100);
    }
  }

  /**
   * 获取当前防守阵容
   */
  getDefenseTeam(): BattleTeam | null {
    return this.defenseTeam;
  }

  // ───────────────────────────────────────────────────────────
  // 私有方法
  // ───────────────────────────────────────────────────────────

  /** 分析阵容推荐策略 */
  private analyzeTeamStrategy(team: BattleTeam): DefenseStrategy {
    const generals = team.generals;
    if (generals.length === 0) return 'balanced';

    // 统计技能类型分布
    let damageCount = 0;
    let healCount = 0;
    let buffCount = 0;
    let debuffCount = 0;

    for (const g of generals) {
      for (const s of g.skills) {
        switch (s.type) {
          case 'damage': damageCount++; break;
          case 'heal': healCount++; break;
          case 'buff': buffCount++; break;
          case 'debuff': debuffCount++; break;
        }
      }
    }

    const total = damageCount + healCount + buffCount + debuffCount;
    if (total === 0) return 'balanced';

    // 判断策略倾向
    if (damageCount / total > 0.6) return 'aggressive';
    if ((healCount + buffCount) / total > 0.5) return 'defensive';
    if (debuffCount / total > 0.3) return 'tactical';
    return 'balanced';
  }

  // ───────────────────────────────────────────────────────────
  // 序列化
  // ───────────────────────────────────────────────────────────

  serialize(): { defenseTeam: BattleTeam | null; defenseStrategy: DefenseStrategy; defenseLog: DefenseRecord[] } {
    return {
      defenseTeam: this.defenseTeam,
      defenseStrategy: this.defenseStrategy,
      defenseLog: this.defenseLog,
    };
  }

  deserialize(data: Record<string, unknown>): void {
    if (data.defenseTeam && typeof data.defenseTeam === 'object') {
      this.defenseTeam = data.defenseTeam as BattleTeam;
    } else {
      this.defenseTeam = null;
    }
    if (typeof data.defenseStrategy === 'string') {
      this.defenseStrategy = data.defenseStrategy as DefenseStrategy;
    }
    if (Array.isArray(data.defenseLog)) {
      this.defenseLog = data.defenseLog as DefenseRecord[];
    }
  }
}

// ═══════════════════════════════════════════════════════════════
// ArenaShop — 竞技商店
// ═══════════════════════════════════════════════════════════════

export class ArenaShop {
  /** 竞技币余额 */
  private arenaCoins: number = 0;
  /** 已购买记录（物品 ID → 已购数量） */
  private shopPurchases: Record<string, number> = {};
  /** 上次日重置时间 */
  private lastDailyResetTime: number = 0;

  /**
   * 获取商店物品列表
   *
   * 根据玩家段位等级过滤可购买物品。
   *
   * @param playerRank 玩家段位等级
   * @returns 可购买的物品列表
   */
  getShopItems(playerRank: number): ArenaShopItem[] {
    this.checkDailyReset();
    return ARENA_SHOP_ITEMS.map(item => {
      const purchased = this.shopPurchases[item.id] ?? 0;
      const remainingStock = item.stock === -1 ? -1 : Math.max(0, item.stock - purchased);
      return {
        ...item,
        stock: remainingStock,
        // 标记是否满足段位要求
        rankRequired: item.rankRequired,
      };
    }).filter(item => item.rankRequired <= playerRank);
  }

  /**
   * 购买物品
   *
   * @param itemId 物品 ID
   * @param arenaCoins 当前竞技币余额
   * @returns 购买是否成功
   */
  purchaseItem(itemId: string, arenaCoins: number): boolean {
    this.checkDailyReset();

    const item = ARENA_SHOP_ITEMS.find(i => i.id === itemId);
    if (!item) return false;

    // 检查库存
    const purchased = this.shopPurchases[itemId] ?? 0;
    if (item.stock !== -1 && purchased >= item.stock) {
      return false;
    }

    // 检查竞技币
    if (arenaCoins < item.cost) {
      return false;
    }

    // 扣除竞技币
    this.arenaCoins = arenaCoins - item.cost;

    // 记录购买
    this.shopPurchases[itemId] = purchased + 1;

    return true;
  }

  /**
   * 设置竞技币余额（由外部同步）
   */
  setArenaCoins(coins: number): void {
    this.arenaCoins = coins;
  }

  /**
   * 获取竞技币余额
   */
  getArenaCoins(): number {
    return this.arenaCoins;
  }

  /**
   * 增加竞技币
   */
  addArenaCoins(amount: number): void {
    this.arenaCoins += amount;
  }

  // ───────────────────────────────────────────────────────────
  // 私有方法
  // ───────────────────────────────────────────────────────────

  /** 检查并执行每日重置 */
  private checkDailyReset(): void {
    const now = Date.now();
    const today = new Date(now).setHours(0, 0, 0, 0);
    if (this.lastDailyResetTime < today) {
      this.shopPurchases = {};
      this.lastDailyResetTime = today;
    }
  }

  // ───────────────────────────────────────────────────────────
  // 序列化
  // ───────────────────────────────────────────────────────────

  serialize(): { arenaCoins: number; shopPurchases: Record<string, number>; lastDailyResetTime: number } {
    return {
      arenaCoins: this.arenaCoins,
      shopPurchases: { ...this.shopPurchases },
      lastDailyResetTime: this.lastDailyResetTime,
    };
  }

  deserialize(data: Record<string, unknown>): void {
    if (typeof data.arenaCoins === 'number') this.arenaCoins = data.arenaCoins;
    if (data.shopPurchases && typeof data.shopPurchases === 'object') {
      this.shopPurchases = data.shopPurchases as Record<string, number>;
    }
    if (typeof data.lastDailyResetTime === 'number') {
      this.lastDailyResetTime = data.lastDailyResetTime;
    }
  }
}

// ═══════════════════════════════════════════════════════════════
// ArenaSystem — 竞技场总控系统
// ═══════════════════════════════════════════════════════════════

export class ArenaSystem {
  /** PvP 匹配器 */
  readonly matchMaker: ArenaMatchMaker;
  /** PvP 战斗引擎 */
  readonly battle: ArenaBattle;
  /** 段位与赛季 */
  readonly ranking: ArenaRanking;
  /** 防守阵容管理 */
  readonly defense: ArenaDefense;
  /** 竞技商店 */
  readonly shop: ArenaShop;

  /** 今日已挑战次数 */
  private dailyChallengesUsed: number = 0;
  /** 上次日重置时间 */
  private lastDailyResetTime: number = 0;

  constructor() {
    this.matchMaker = new ArenaMatchMaker();
    this.battle = new ArenaBattle();
    this.ranking = new ArenaRanking();
    this.defense = new ArenaDefense();
    this.shop = new ArenaShop();
  }

  // ───────────────────────────────────────────────────────────
  // 核心流程
  // ───────────────────────────────────────────────────────────

  /**
   * 发起挑战
   *
   * 完整的挑战流程：检查次数 → 执行战斗 → 更新积分 → 发放奖励 → 记录防守
   *
   * @param attacker 攻方队伍
   * @param opponentIndex 对手索引（0-4）
   * @returns 战斗结果，或 null 表示无法挑战
   */
  challengeOpponent(attacker: BattleTeam, opponentIndex: number): ArenaBattleResult | null {
    this.checkDailyReset();

    // 检查挑战次数
    if (this.dailyChallengesUsed >= DAILY_CHALLENGE_MAX) {
      return null;
    }

    // 获取对手
    const opponents = this.matchMaker.getCurrentOpponents();
    if (opponentIndex < 0 || opponentIndex >= opponents.length) {
      return null;
    }

    // 构建防守方队伍
    const defender = this.buildDefenderTeam(opponents[opponentIndex]);

    // 执行战斗
    const result = this.battle.executeBattle(attacker, defender);

    // 更新积分
    this.ranking.updatePoints(result.pointsChange);
    this.ranking.recordResult(result.victory);

    // 发放竞技币
    this.shop.addArenaCoins(result.arenaCoins);

    // 记录防守日志
    this.defense.recordDefense({
      attackerId: opponents[opponentIndex].id,
      attackerName: opponents[opponentIndex].name,
      result: result.victory ? 'lose' : 'win',
      timestamp: Date.now(),
      attackerPower: opponents[opponentIndex].power,
      remainingHpPercent: result.victory ? 0 : Math.round(
        (defender.generals.reduce((s, g) => s + g.hp, 0) /
          Math.max(1, defender.generals.reduce((s, g) => s + g.maxHp, 0)) * 100)
      ),
    });

    // 消耗挑战次数
    this.dailyChallengesUsed++;

    return result;
  }

  /**
   * 获取挑战信息
   */
  getChallengeInfo(): { dailyUsed: number; dailyMax: number; freeRefreshTime: number } {
    this.checkDailyReset();
    const refreshInfo = this.matchMaker.getChallengeInfo();
    return {
      dailyUsed: this.dailyChallengesUsed,
      dailyMax: DAILY_CHALLENGE_MAX,
      freeRefreshTime: refreshInfo.freeRefreshTime,
    };
  }

  /**
   * 刷新对手
   */
  refreshOpponents(playerPower: number, playerRank: number, costGold: number = 0): boolean {
    const success = this.matchMaker.refreshOpponents(costGold);
    if (success) {
      this.matchMaker.selectOpponents(playerPower, playerRank);
    }
    return success;
  }

  // ───────────────────────────────────────────────────────────
  // 私有方法
  // ───────────────────────────────────────────────────────────

  /** 检查并执行每日重置 */
  private checkDailyReset(): void {
    const now = Date.now();
    const today = new Date(now).setHours(0, 0, 0, 0);
    if (this.lastDailyResetTime < today) {
      this.dailyChallengesUsed = 0;
      this.lastDailyResetTime = today;
    }
  }

  /** 根据 AI 对手信息构建防守方队伍 */
  private buildDefenderTeam(opponent: ArenaOpponent): BattleTeam {
    const generals: BattleGeneral[] = opponent.team.map((g, i) => ({
      id: g.id,
      name: g.name,
      hp: 500 + g.level * 50,
      maxHp: 500 + g.level * 50,
      attack: 30 + g.level * 10,
      defense: 20 + g.level * 8,
      speed: 50 + g.level * 2 + Math.floor(Math.random() * 20),
      skills: [
        { id: `skill_${g.id}_1`, name: '普攻', multiplier: 1.0, cooldown: 0, currentCooldown: 0, type: 'damage' },
        { id: `skill_${g.id}_2`, name: '战技', multiplier: 1.5, cooldown: 2, currentCooldown: 0, type: 'damage' },
      ],
      isAlive: true,
    }));

    return {
      generals,
      totalPower: opponent.power,
      faction: 'neutral',
    };
  }

  // ───────────────────────────────────────────────────────────
  // 序列化 / 反序列化
  // ───────────────────────────────────────────────────────────

  /**
   * 序列化竞技场全部数据
   */
  serialize(): ArenaSaveData {
    const matchMakerData = this.matchMaker.serialize();
    const rankingData = this.ranking.serialize();
    const defenseData = this.defense.serialize();
    const shopData = this.shop.serialize();

    return {
      points: rankingData.points,
      seasonNumber: rankingData.seasonNumber,
      seasonStartTime: rankingData.seasonStartTime,
      dailyChallengesUsed: this.dailyChallengesUsed,
      lastFreeRefreshTime: matchMakerData.lastFreeRefreshTime,
      dailyRefreshUsed: matchMakerData.dailyRefreshUsed,
      arenaCoins: shopData.arenaCoins,
      opponents: matchMakerData.opponents,
      defenseTeam: defenseData.defenseTeam,
      defenseStrategy: defenseData.defenseStrategy,
      defenseLog: defenseData.defenseLog,
      shopPurchases: shopData.shopPurchases,
      lastDailyResetTime: this.lastDailyResetTime,
      highestRank: rankingData.highestRank,
      seasonWins: rankingData.seasonWins,
      seasonLosses: rankingData.seasonLosses,
    };
  }

  /**
   * 反序列化竞技场数据
   */
  deserialize(data: ArenaSaveData): void {
    // 恢复各子系统
    this.matchMaker.deserialize({
      opponents: data.opponents,
      lastFreeRefreshTime: data.lastFreeRefreshTime,
      dailyRefreshUsed: data.dailyRefreshUsed,
    });

    this.ranking.deserialize({
      points: data.points,
      seasonNumber: data.seasonNumber,
      seasonStartTime: data.seasonStartTime,
      highestRank: data.highestRank,
      seasonWins: data.seasonWins,
      seasonLosses: data.seasonLosses,
    });

    this.defense.deserialize({
      defenseTeam: data.defenseTeam,
      defenseStrategy: data.defenseStrategy,
      defenseLog: data.defenseLog,
    });

    this.shop.deserialize({
      arenaCoins: data.arenaCoins,
      shopPurchases: data.shopPurchases,
    });

    if (typeof data.dailyChallengesUsed === 'number') {
      this.dailyChallengesUsed = data.dailyChallengesUsed;
    }
    if (typeof data.lastDailyResetTime === 'number') {
      this.lastDailyResetTime = data.lastDailyResetTime;
    }
  }
}
