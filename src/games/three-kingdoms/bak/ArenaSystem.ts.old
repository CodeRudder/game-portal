/**
 * 三国霸业 — 竞技场系统 v11.0「群雄逐鹿」
 *
 * 提供 PvP 匹配、战斗、段位赛季、防守阵容、竞技商店五大子系统。
 * 参考《三国志》/《率土之滨》的竞技场设计理念：
 * - 战力匹配：在玩家战力 ±30% 范围内选取对手
 * - 段位赛季：21 级段位（青铜 V ~ 王者），28 天赛季周期
 * - 防守布阵：攻守异势，防守方享有 +10% 属性加成
 * - 竞技商店：使用竞技币兑换武将碎片、强化石等稀有资源
 *
 * @module games/three-kingdoms/ArenaSystem
 */

// ═══════════════════════════════════════════════════════════════
// 类型定义
// ═══════════════════════════════════════════════════════════════

/** 竞技场对手信息 */
export interface ArenaOpponent {
  /** 对手唯一 ID */
  id: string;
  /** 对手名称 */
  name: string;
  /** 对手战力 */
  power: number;
  /** 对手段位等级（1-21） */
  rank: number;
  /** 对手阵容武将概要 */
  team: GeneralInfo[];
  /** 对手防守策略 */
  defenseStrategy: string;
}

/** 武将概要信息 */
export interface GeneralInfo {
  /** 武将 ID */
  id: string;
  /** 武将名称 */
  name: string;
  /** 武将等级 */
  level: number;
  /** 武将稀有度 */
  rarity: string;
  /** 武将位置（前排/后排） */
  position: 'front' | 'back';
}

/** 战斗队伍 */
export interface BattleTeam {
  /** 队伍武将列表 */
  generals: BattleGeneral[];
  /** 队伍总战力 */
  totalPower: number;
  /** 队伍阵营 */
  faction: string;
}

/** 战斗中的武将 */
export interface BattleGeneral {
  /** 武将 ID */
  id: string;
  /** 武将名称 */
  name: string;
  /** 当前 HP */
  hp: number;
  /** 最大 HP */
  maxHp: number;
  /** 攻击力 */
  attack: number;
  /** 防御力 */
  defense: number;
  /** 速度（决定行动顺序） */
  speed: number;
  /** 技能列表 */
  skills: BattleSkill[];
  /** 是否存活 */
  isAlive: boolean;
}

/** 武将技能 */
export interface BattleSkill {
  /** 技能 ID */
  id: string;
  /** 技能名称 */
  name: string;
  /** 技能伤害倍率 */
  multiplier: number;
  /** 冷却回合数 */
  cooldown: number;
  /** 当前冷却剩余 */
  currentCooldown: number;
  /** 技能类型 */
  type: 'damage' | 'heal' | 'buff' | 'debuff';
}

/** 单回合战斗记录 */
export interface BattleRound {
  /** 回合编号（1-10） */
  round: number;
  /** 本回合行动序列 */
  actions: BattleAction[];
  /** 攻方剩余总 HP */
  attackerHp: number;
  /** 守方剩余总 HP */
  defenderHp: number;
}

/** 战斗行动 */
export interface BattleAction {
  /** 行动者名称 */
  actor: string;
  /** 行动者阵营 */
  side: 'attacker' | 'defender';
  /** 使用技能名称 */
  skill: string;
  /** 目标名称 */
  target: string;
  /** 造成伤害/治疗量 */
  value: number;
  /** 行动类型 */
  type: 'damage' | 'heal' | 'buff' | 'debuff';
}

/** 竞技场战斗结果 */
export interface ArenaBattleResult {
  /** 是否胜利 */
  victory: boolean;
  /** 积分变化（正为增加） */
  pointsChange: number;
  /** 获得的竞技币 */
  arenaCoins: number;
  /** 战斗回合数 */
  rounds: number;
  /** 战斗回放数据 */
  replay: BattleRound[];
}

/** 竞技商店物品 */
export interface ArenaShopItem {
  /** 物品 ID */
  id: string;
  /** 物品名称 */
  name: string;
  /** 价格（竞技币） */
  cost: number;
  /** 物品分类 */
  category: 'general_shard' | 'enhance_stone' | 'equipment_box' | 'avatar_frame' | 'resource';
  /** 所需段位等级 */
  rankRequired: number;
  /** 库存（-1 表示不限量） */
  stock: number;
  /** 物品描述 */
  description: string;
}

/** 防守记录 */
export interface DefenseRecord {
  /** 进攻者 ID */
  attackerId: string;
  /** 进攻者名称 */
  attackerName: string;
  /** 防守结果 */
  result: 'win' | 'lose';
  /** 时间戳 */
  timestamp: number;
  /** 进攻者战力 */
  attackerPower: number;
  /** 防守方剩余 HP 百分比 */
  remainingHpPercent: number;
}

/** 奖励 */
export interface Reward {
  /** 奖励类型 */
  type: string;
  /** 奖励 ID */
  id: string;
  /** 奖励名称 */
  name: string;
  /** 数量 */
  amount: number;
}

/** 段位定义 */
export interface ArenaTierDef {
  /** 段位名称 */
  name: string;
  /** 段位等级（1-21） */
  level: number;
  /** 积分下限 */
  minPoints: number;
  /** 积分上限（含） */
  maxPoints: number;
  /** 段位图标 */
  icon: string;
  /** 大段位分类 */
  tier: ArenaTier;
  /** 小段位 */
  division: number;
}

/** 段位大类 */
export type ArenaTier = 'bronze' | 'silver' | 'gold' | 'platinum' | 'diamond' | 'master' | 'grandmaster' | 'king';

/** 防守策略类型 */
export type DefenseStrategy = 'balanced' | 'aggressive' | 'defensive' | 'tactical';

/** 竞技场存档数据 */
export interface ArenaSaveData {
  /** 当前积分 */
  points: number;
  /** 赛季编号 */
  seasonNumber: number;
  /** 赛季开始时间戳 */
  seasonStartTime: number;
  /** 今日已挑战次数 */
  dailyChallengesUsed: number;
  /** 上次免费刷新时间 */
  lastFreeRefreshTime: number;
  /** 今日已刷新次数 */
  dailyRefreshUsed: number;
  /** 竞技币余额 */
  arenaCoins: number;
  /** 当前对手列表 */
  opponents: ArenaOpponent[];
  /** 防守阵容 */
  defenseTeam: BattleTeam | null;
  /** 防守策略 */
  defenseStrategy: DefenseStrategy;
  /** 防守日志 */
  defenseLog: DefenseRecord[];
  /** 商店购买记录（物品 ID → 已购数量） */
  shopPurchases: Record<string, number>;
  /** 上次日重置时间 */
  lastDailyResetTime: number;
  /** 历史最高段位等级 */
  highestRank: number;
  /** 赛季累计胜场 */
  seasonWins: number;
  /** 赛季累计负场 */
  seasonLosses: number;
}

// ═══════════════════════════════════════════════════════════════
// 常量
// ═══════════════════════════════════════════════════════════════

