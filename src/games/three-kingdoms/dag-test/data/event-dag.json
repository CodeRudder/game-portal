  "relations": [
    {
      "from": "evt-game-initialized",
      "to": "evt-resource-changed",
      "listener": "UI",
      "type": "cascade",
      "handler": "初始化后刷新资源面板显示"
    },
    {
      "from": "evt-game-initialized",
      "to": "evt-tutorial-first-launch-detected",
      "listener": "FirstLaunchDetector",
      "type": "cascade",
      "handler": "首次启动时触发新手引导检测"
    },
    {
      "from": "evt-game-loaded",
      "to": "evt-game-offline-earnings",
      "listener": "UI",
      "type": "cascade",
      "handler": "加载存档后计算并展示离线收益"
    },
    {
      "from": "evt-game-offline-earnings",
      "to": "evt-resource-changed",
      "listener": "ResourceSystem",
      "type": "cascade",
      "handler": "领取离线收益后更新资源数量"
    },
    {
      "from": "evt-building-upgrade-start",
      "to": "evt-resource-changed",
      "listener": "UI",
      "type": "cascade",
      "handler": "建筑开始升级时扣除资源并刷新显示"
    },
    {
      "from": "evt-building-upgraded",
      "to": "evt-resource-rate-changed",
      "listener": "engine-tick",
      "type": "cascade",
      "handler": "建筑升级完成后重新计算产出速率"
    },
    {
      "from": "evt-building-upgraded",
      "to": "evt-resource-changed",
      "listener": "UI",
      "type": "cascade",
      "handler": "建筑升级完成后刷新资源面板"
    },
    {
      "from": "evt-building-upgraded",
      "to": "evt-building-unlocked",
      "listener": "BuildingSystem",
      "type": "cascade",
      "handler": "主城升级可能解锁新建筑"
    },
    {
      "from": "evt-building-upgraded",
      "to": "evt-quest-progress",
      "listener": "QuestTrackerSystem",
      "type": "cascade",
      "handler": "建筑升级完成推进相关任务进度"
    },
    {
      "from": "evt-resource-overflow",
      "to": "evt-resource-cap-warning",
      "listener": "UI",
      "type": "cascade",
      "handler": "资源溢出时触发容量警告"
    },
