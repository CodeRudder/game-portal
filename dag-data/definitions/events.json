{
  "id": "event-bus-v1",
  "name": "三国放置游戏 — 事件关系DAG",
  "events": [
    { "id": "evt-resource-changed", "eventType": "resource:changed", "emitter": "engine-tick / engine-building-ops", "payload": "{ resources: Resources }", "version": "v1.0" },
    { "id": "evt-resource-rate-changed", "eventType": "resource:rate-changed", "emitter": "engine-tick", "payload": "{ rates: ProductionRate }", "version": "v1.0" },
    { "id": "evt-resource-overflow", "eventType": "resource:overflow", "emitter": "ResourceSystem", "payload": "{ resourceType, requested, actual, overflow, cap, current }", "version": "v1.0" },
    { "id": "evt-resource-cap-warning", "eventType": "resource:cap-warning", "emitter": "ResourceSystem", "payload": "{ warnings: CapWarning[] }", "version": "v1.0" },
    { "id": "evt-building-upgrade-start", "eventType": "building:upgrade-start", "emitter": "engine-building-ops", "payload": "{ type: BuildingType, cost: UpgradeCost }", "version": "v1.0" },
    { "id": "evt-building-upgraded", "eventType": "building:upgraded", "emitter": "engine-tick", "payload": "{ type: BuildingType, level: number }", "version": "v1.0" },
    { "id": "evt-building-unlocked", "eventType": "building:unlocked", "emitter": "BuildingSystem", "payload": "{ types: BuildingType[] }", "version": "v1.0" },
    { "id": "evt-game-initialized", "eventType": "game:initialized", "emitter": "ThreeKingdomsEngine", "payload": "{ isNewGame: boolean }", "version": "v1.0" },
    { "id": "evt-game-loaded", "eventType": "game:loaded", "emitter": "ThreeKingdomsEngine", "payload": "{ offlineEarnings?: OfflineEarnings }", "version": "v1.0" },
    { "id": "evt-game-saved", "eventType": "game:saved", "emitter": "ThreeKingdomsEngine", "payload": "{ timestamp: number }", "version": "v1.0" },
    { "id": "evt-game-offline-earnings", "eventType": "game:offline-earnings", "emitter": "OfflineRewardSystem", "payload": "OfflineEarnings", "version": "v1.0" },
    { "id": "evt-calendar-day-changed", "eventType": "calendar:dayChanged", "emitter": "CalendarSystem", "payload": "{ day, month, year, season }", "version": "v1.0" },
    { "id": "evt-calendar-season-changed", "eventType": "calendar:seasonChanged", "emitter": "CalendarSystem", "payload": "{ season, day }", "version": "v1.0" },
    { "id": "evt-weather-changed", "eventType": "weather:changed", "emitter": "CalendarSystem", "payload": "{ weather, territoryId }", "version": "v4.0" },
    { "id": "evt-economy-tech-researched", "eventType": "economy:techResearched", "emitter": "TechResearchSystem", "payload": "{ techId, path, tier }", "version": "v4.0" },
    { "id": "evt-economy-tech-completed", "eventType": "economy:techCompleted", "emitter": "TechTreeSystem", "payload": "{ techId, path, effects }", "version": "v4.0" },
    { "id": "evt-economy-fusion-tech-completed", "eventType": "economy:fusionTechCompleted", "emitter": "FusionTechSystem", "payload": "{ fusionId, effects }", "version": "v5.0" },
    { "id": "evt-tech-links-changed", "eventType": "tech:linksChanged", "emitter": "TechLinkSystem", "payload": "{ linkId, action }", "version": "v5.0" },
    { "id": "evt-tech-offline-completed", "eventType": "tech:offlineResearchCompleted", "emitter": "TechOfflineSystem", "payload": "{ techId, pointsEarned }", "version": "v5.0" },
    { "id": "evt-quest-accepted", "eventType": "quest:accepted", "emitter": "QuestSystem", "payload": "{ instanceId, questId }", "version": "v1.0" },
    { "id": "evt-quest-progress", "eventType": "quest:progress", "emitter": "QuestSystem", "payload": "{ instanceId, questId, progress, target }", "version": "v1.0" },
    { "id": "evt-quest-completed", "eventType": "quest:completed", "emitter": "QuestSystem", "payload": "{ instanceId, questId, rewards }", "version": "v1.0" },
    { "id": "evt-quest-daily-refreshed", "eventType": "quest:dailyRefreshed", "emitter": "QuestSystem", "payload": "{ newQuests }", "version": "v1.0" },
    { "id": "evt-quest-activity-changed", "eventType": "quest:activityChanged", "emitter": "ActivitySystem", "payload": "{ activityId, points }", "version": "v1.0" },
    { "id": "evt-achievement-completed", "eventType": "achievement:completed", "emitter": "AchievementSystem", "payload": "{ achievementId, category, reward }", "version": "v14.0" },
    { "id": "evt-achievement-chain-completed", "eventType": "achievement:chainCompleted", "emitter": "AchievementSystem", "payload": "{ chainId, totalRewards }", "version": "v14.0" },
    { "id": "evt-prestige-level-up", "eventType": "prestige:levelUp", "emitter": "PrestigeSystem", "payload": "{ level, points, bonus }", "version": "v14.0" },
    { "id": "evt-rebirth-completed", "eventType": "rebirth:completed", "emitter": "RebirthSystem", "payload": "{ count, multiplier, acceleration }", "version": "v14.0" },
    { "id": "evt-rebirth-acceleration-ended", "eventType": "rebirth:accelerationEnded", "emitter": "RebirthSystem", "payload": "{ rebirthCount }", "version": "v14.0" },
    { "id": "evt-prestige-shop-purchased", "eventType": "prestigeShop:purchased", "emitter": "PrestigeShopSystem", "payload": "{ goodsId, cost }", "version": "v14.0" },
    { "id": "evt-shop-goods-purchased", "eventType": "shop:goods_purchased", "emitter": "ShopSystem", "payload": "{ goodsId, quantity, shopType, cost }", "version": "v1.0" },
    { "id": "evt-bond-activated", "eventType": "bond:activated", "emitter": "BondSystem(hero)", "payload": "{ bondId, heroes, effects }", "version": "v2.0" },
    { "id": "evt-bond-level-up", "eventType": "bond:levelUp", "emitter": "BondSystem(hero)", "payload": "{ bondId, level }", "version": "v2.0" },
    { "id": "evt-bond-deactivated", "eventType": "bond:deactivated", "emitter": "BondSystem(hero)", "payload": "{ bondId, reason }", "version": "v2.0" },
    { "id": "evt-bond-story-triggered", "eventType": "bond:storyTriggered", "emitter": "BondSystem(engine)", "payload": "{ bondId, storyId, chapter }", "version": "v2.0" },
    { "id": "evt-territory-captured", "eventType": "territory:captured", "emitter": "TerritorySystem", "payload": "{ territoryId, owner }", "version": "v4.0" },
    { "id": "evt-territory-upgraded", "eventType": "territory:upgraded", "emitter": "TerritorySystem", "payload": "{ territoryId, level }", "version": "v4.0" },
    { "id": "evt-siege-victory", "eventType": "siege:victory", "emitter": "SiegeSystem", "payload": "{ territoryId, attacker, defender }", "version": "v4.0" },
    { "id": "evt-siege-defeat", "eventType": "siege:defeat", "emitter": "SiegeSystem", "payload": "{ territoryId, attacker, defender }", "version": "v4.0" },
    { "id": "evt-siege-reward", "eventType": "siege:reward", "emitter": "SiegeEnhancer", "payload": "{ territoryId, rewards }", "version": "v4.0" },
    { "id": "evt-siege-auto-garrison", "eventType": "siege:autoGarrison", "emitter": "SiegeSystem", "payload": "{ territoryId, heroIds }", "version": "v4.0" },
    { "id": "evt-garrison-assigned", "eventType": "garrison:assigned", "emitter": "GarrisonSystem", "payload": "{ territoryId, heroId }", "version": "v4.0" },
    { "id": "evt-garrison-withdrawn", "eventType": "garrison:withdrawn", "emitter": "GarrisonSystem", "payload": "{ territoryId, heroId }", "version": "v4.0" },
    { "id": "evt-season-created", "eventType": "season:created", "emitter": "SeasonSystem", "payload": "{ seasonId, name, duration }", "version": "v16.0" },
    { "id": "evt-season-settled", "eventType": "season:settled", "emitter": "SeasonSystem", "payload": "{ seasonId, rankings, rewards }", "version": "v16.0" },
    { "id": "evt-event-triggered", "eventType": "event:triggered", "emitter": "EventTriggerSystem", "payload": "{ eventDefId, instanceId }", "version": "v7.0" },
    { "id": "evt-event-resolved", "eventType": "event:resolved", "emitter": "EventTriggerLifecycle", "payload": "{ instanceId, outcome }", "version": "v7.0" },
    { "id": "evt-event-expired", "eventType": "event:expired", "emitter": "EventTriggerLifecycle", "payload": "{ instanceId }", "version": "v7.0" },
    { "id": "evt-event-banner-created", "eventType": "event:banner_created", "emitter": "EventNotificationSystem", "payload": "{ bannerId, title, urgency }", "version": "v7.0" },
    { "id": "evt-event-encounter-created", "eventType": "event:encounter_created", "emitter": "EventNotificationSystem", "payload": "{ encounterId, title, optionCount }", "version": "v7.0" },
    { "id": "evt-event-encounter-resolved", "eventType": "event:encounter_resolved", "emitter": "EventNotificationSystem", "payload": "{ encounterId, optionId, consequences }", "version": "v7.0" },
    { "id": "evt-story-triggered", "eventType": "story:triggered", "emitter": "StoryEventSystem", "payload": "{ storyId, title, era }", "version": "v7.0" },
    { "id": "evt-story-completed", "eventType": "story:completed", "emitter": "StoryEventSystem", "payload": "{ storyId, title, era }", "version": "v7.0" },
    { "id": "evt-chain-started", "eventType": "chain:started", "emitter": "ChainEventSystem", "payload": "{ chainId, title }", "version": "v7.0" },
    { "id": "evt-chain-completed", "eventType": "chain:completed", "emitter": "ChainEventSystem", "payload": "{ chainId, rewards }", "version": "v7.0" },
    { "id": "evt-advisor-suggestion", "eventType": "advisor:suggestionExecuted", "emitter": "AdvisorSystem", "payload": "{ suggestionId, type }", "version": "v1.0" },
    { "id": "evt-tutorial-first-launch", "eventType": "tutorial:firstLaunchDetected", "emitter": "FirstLaunchDetector", "payload": "{ isNewPlayer, platform }", "version": "v1.0" },
    { "id": "evt-tutorial-reward", "eventType": "tutorial:rewardGranted", "emitter": "TutorialStepExecutor", "payload": "{ stepId, rewards }", "version": "v1.0" },
    { "id": "evt-npc-spawned", "eventType": "npc:spawned", "emitter": "NPCSpawnSystem", "payload": "{ npcId, ruleId, defId }", "version": "v6.0" },
    { "id": "evt-npc-gift-given", "eventType": "npc:gift_given", "emitter": "NPCGiftSystem", "payload": "{ npcId, giftId, favorability }", "version": "v6.0" },
    { "id": "evt-npc-affinity-changed", "eventType": "npc:affinity_changed", "emitter": "NPCSystem/NPCAffinitySystem", "payload": "{ npcId, delta, affinity, source }", "version": "v6.0" },
    { "id": "evt-hero-recruited", "eventType": "hero:recruited", "emitter": "HeroRecruitSystem", "payload": "{ heroId, star, cost }", "version": "v2.0" }
  ],
  "relations": [
    { "from": "evt-resource-changed", "to": "evt-quest-progress", "type": "cascade", "listener": "QuestTrackerSystem", "handler": "资源变化触发任务进度更新(如收集类任务)" },
    { "from": "evt-building-upgrade-start", "to": "evt-resource-changed", "type": "cascade", "listener": "engine-building-ops", "handler": "建筑升级开始时扣除资源，emit resource:changed" },
    { "from": "evt-building-upgraded", "to": "evt-resource-rate-changed", "type": "cascade", "listener": "engine-tick", "handler": "建筑升级完成，同步产出速率，emit resource:rate-changed" },
    { "from": "evt-building-upgraded", "to": "evt-achievement-completed", "type": "cascade", "listener": "AchievementSystem", "handler": "建筑升级，检查建筑成就(累计升级次数/等级)" },
    { "from": "evt-building-upgraded", "to": "evt-quest-progress", "type": "cascade", "listener": "QuestTrackerSystem", "handler": "建筑升级，更新建筑相关任务进度" },
    { "from": "evt-calendar-day-changed", "to": "evt-quest-daily-refreshed", "type": "cascade", "listener": "QuestSystem", "handler": "日历日变更，刷新日常任务" },
    { "from": "evt-calendar-day-changed", "to": "evt-quest-activity-changed", "type": "cascade", "listener": "ActivitySystem", "handler": "日历日变更，重置活动活跃度" },
    { "from": "evt-calendar-day-changed", "to": "evt-advisor-suggestion", "type": "cascade", "listener": "AdvisorSystem", "handler": "日历日变更，重置军师建议(AdvisorSystem.on)" },
    { "from": "evt-calendar-day-changed", "to": "evt-prestige-level-up", "type": "cascade", "listener": "PrestigeSystem", "handler": "日历日变更，重置每日声望获取上限" },
    { "from": "evt-calendar-day-changed", "to": "evt-rebirth-completed", "type": "cascade", "listener": "RebirthSystem", "handler": "日历日变更，检查转生加速到期" },
    { "from": "evt-calendar-day-changed", "to": "evt-resource-changed", "type": "cascade", "listener": "HeritageSystem", "handler": "日历日变更，重置传承每日计数" },
    { "from": "evt-prestige-level-up", "to": "evt-prestige-shop-purchased", "type": "cascade", "listener": "PrestigeShopSystem", "handler": "声望升级，解锁新商品" },
    { "from": "evt-prestige-level-up", "to": "evt-achievement-completed", "type": "cascade", "listener": "AchievementSystem", "handler": "声望升级，检查声望成就" },
    { "from": "evt-rebirth-completed", "to": "evt-achievement-completed", "type": "cascade", "listener": "AchievementSystem", "handler": "转生完成，检查转生成就" },
    { "from": "evt-hero-recruited", "to": "evt-achievement-completed", "type": "cascade", "listener": "AchievementSystem", "handler": "武将招募，检查招募成就" },
    { "from": "evt-hero-recruited", "to": "evt-bond-activated", "type": "cascade", "listener": "BondSystem", "handler": "武将招募，检查羁绊激活条件" },
    { "from": "evt-hero-recruited", "to": "evt-quest-progress", "type": "cascade", "listener": "QuestTrackerSystem", "handler": "武将招募，更新招募相关任务进度" },
    { "from": "evt-quest-completed", "to": "evt-resource-changed", "type": "cascade", "listener": "QuestSystem", "handler": "任务完成，发放奖励资源" },
    { "from": "evt-quest-completed", "to": "evt-quest-activity-changed", "type": "cascade", "listener": "ActivitySystem", "handler": "任务完成，增加活跃度积分" },
    { "from": "evt-event-triggered", "to": "evt-event-banner-created", "type": "cascade", "listener": "EventNotificationSystem", "handler": "事件触发，创建UI横幅通知" },
    { "from": "evt-event-triggered", "to": "evt-event-encounter-created", "type": "cascade", "listener": "EventNotificationSystem", "handler": "事件触发，创建遭遇弹窗" },
    { "from": "evt-event-encounter-resolved", "to": "evt-event-resolved", "type": "cascade", "listener": "EventTriggerLifecycle", "handler": "遭遇选择，事件解决" },
    { "from": "evt-event-triggered", "to": "evt-event-expired", "type": "cascade", "listener": "EventTriggerLifecycle", "handler": "事件超时未处理，事件过期" },
    { "from": "evt-story-triggered", "to": "evt-story-completed", "type": "cascade", "listener": "StoryEventSystem", "handler": "剧情触发，推进剧情章节，完成" },
    { "from": "evt-chain-started", "to": "evt-chain-completed", "type": "cascade", "listener": "ChainEventSystem", "handler": "事件链开始，逐步推进，完成" },
    { "from": "evt-siege-victory", "to": "evt-territory-captured", "type": "cascade", "listener": "TerritorySystem", "handler": "攻城胜利，领土占领" },
    { "from": "evt-siege-victory", "to": "evt-siege-reward", "type": "cascade", "listener": "SiegeEnhancer", "handler": "攻城胜利，发放攻城奖励" },
    { "from": "evt-siege-victory", "to": "evt-siege-auto-garrison", "type": "cascade", "listener": "SiegeSystem", "handler": "攻城胜利，自动驻防" },
    { "from": "evt-territory-captured", "to": "evt-resource-rate-changed", "type": "cascade", "listener": "ResourceSystem", "handler": "领土占领，更新资源产出加成" },
    { "from": "evt-season-settled", "to": "evt-resource-changed", "type": "cascade", "listener": "ResourceSystem", "handler": "赛季结算，发放赛季奖励" },
    { "from": "evt-npc-gift-given", "to": "evt-npc-affinity-changed", "type": "cascade", "listener": "NPCAffinitySystem", "handler": "NPC赠礼，好感度变化" },
    { "from": "evt-npc-affinity-changed", "to": "evt-quest-progress", "type": "cascade", "listener": "QuestTrackerSystem", "handler": "NPC好感度变化，更新相关任务进度" },
    { "from": "evt-tutorial-first-launch", "to": "evt-tutorial-reward", "type": "cascade", "listener": "TutorialStepExecutor", "handler": "首次启动，教程流程，发放教程奖励" },
    { "from": "evt-game-initialized", "to": "evt-tutorial-first-launch", "type": "cascade", "listener": "FirstLaunchDetector", "handler": "游戏初始化，检测是否首次启动" },
    { "from": "evt-game-loaded", "to": "evt-game-offline-earnings", "type": "cascade", "listener": "OfflineRewardSystem", "handler": "读档完成，计算离线收益" },
    { "from": "evt-economy-tech-completed", "to": "evt-resource-rate-changed", "type": "cascade", "listener": "TechEffectApplier", "handler": "科技完成，应用产出加成，更新资源速率" },
    { "from": "evt-economy-fusion-tech-completed", "to": "evt-tech-links-changed", "type": "cascade", "listener": "TechLinkSystem", "handler": "融合科技完成，更新链接关系" },
    { "from": "evt-resource-overflow", "to": "evt-resource-cap-warning", "type": "cascade", "listener": "ResourceSystem", "handler": "资源溢出，触发容量警告" },
    { "from": "evt-achievement-completed", "to": "evt-achievement-chain-completed", "type": "cascade", "listener": "AchievementSystem", "handler": "单个成就完成，检查成就链是否完成" },
    { "from": "evt-achievement-completed", "to": "evt-resource-changed", "type": "cascade", "listener": "ResourceSystem", "handler": "成就完成，发放奖励资源" },
    { "from": "evt-bond-activated", "to": "evt-bond-story-triggered", "type": "cascade", "listener": "BondSystem", "handler": "羁绊激活，触发羁绊剧情" },
    { "from": "evt-bond-level-up", "to": "evt-bond-story-triggered", "type": "cascade", "listener": "BondSystem", "handler": "羁绊升级，触发新章节剧情" }
  ]
}
