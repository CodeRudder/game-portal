  "transitions": [
    {
      "from": "building:locked",
      "to": "building:idle",
      "trigger": "unlock",
      "condition": "主城等级 >= 建筑解锁等级",
      "sideEffects": [
        "建筑解锁动画",
        "新手引导触发"
      ]
    },
    {
      "from": "building:idle",
      "to": "building:upgrading",
      "trigger": "startUpgrade",
      "condition": "资源充足 && 队列有空位",
      "sideEffects": [
        "扣除升级资源",
        "开始倒计时"
      ]
    },
    {
      "from": "building:upgrading",
      "to": "building:idle",
      "trigger": "upgradeComplete",
      "condition": "倒计时结束",
      "sideEffects": [
        "建筑等级+1",
        "产出提升",
        "解锁新功能"
      ]
    },
    {
      "from": "building:upgrading",
      "to": "building:idle",
      "trigger": "cancelUpgrade",
      "condition": "玩家主动取消",
      "sideEffects": [
        "返还部分资源"
      ]
    },
    {
      "from": "hero:locked",
      "to": "hero:available",
      "trigger": "unlockHero",
      "condition": "完成解锁条件(剧情/声望等级)",
      "sideEffects": [
        "武将出现在招贤池"
      ]
    },
    {
      "from": "hero:available",
      "to": "hero:recruited",
      "trigger": "recruit",
      "condition": "招贤令/铜钱充足",
      "sideEffects": [
        "扣除招贤令",
        "武将加入阵容"
      ]
    },
    {
      "from": "hero:recruited",
      "to": "hero:dispatched",
      "trigger": "dispatch",
      "condition": "远征/派遣任务可用",
      "sideEffects": [
        "武将进入派遣状态",
        "不可出战"
      ]
    },
    {
      "from": "hero:dispatched",
      "to": "hero:recruited",
      "trigger": "dispatchComplete",
      "condition": "派遣任务完成",
      "sideEffects": [
        "获得派遣奖励"
      ]
    },
    {
      "from": "hero:recruited",
      "to": "hero:awakening",
      "trigger": "startAwakening",
      "condition": "武将突破满星 && 觉醒材料充足",
      "sideEffects": [
        "扣除觉醒材料"
      ]
    },
    {
      "from": "hero:awakening",
      "to": "hero:awakened",
      "trigger": "awakeningComplete",
      "condition": "觉醒流程完成",
      "sideEffects": [
        "武将属性大幅提升",
        "解锁觉醒技能"
      ]
    },
    {
      "from": "quest:locked",
      "to": "quest:available",
      "trigger": "unlockQuest",
      "condition": "前置任务完成 && 等级达标",
      "sideEffects": [
        "任务出现在列表",
        "红点提示"
      ]
    },
    {
      "from": "quest:available",
      "to": "quest:active",
      "trigger": "acceptQuest",
      "condition": "玩家接取任务",
      "sideEffects": [
        "任务追踪开始"
      ]
    },
    {
      "from": "quest:active",
      "to": "quest:completed",
      "trigger": "completeObjective",
      "condition": "任务目标达成",
      "sideEffects": [
        "任务标记完成",
        "红点提示领奖"
      ]
    },
    {
      "from": "quest:active",
      "to": "quest:failed",
      "trigger": "failQuest",
      "condition": "任务失败条件触发",
      "sideEffects": [
        "任务标记失败"
      ]
    },
    {
      "from": "quest:active",
      "to": "quest:expired",
      "trigger": "expireQuest",
      "condition": "任务超时",
      "sideEffects": [
        "任务标记过期"
      ]
    },
    {
      "from": "quest:completed",
      "to": "quest:claimed",
      "trigger": "claimReward",
      "condition": "玩家领取奖励",
      "sideEffects": [
        "发放奖励资源",
        "关闭任务"
      ]
    },
    {
      "from": "tech:locked",
      "to": "tech:available",
      "trigger": "unlockTech",
      "condition": "前置科技已研究完成 && 非互斥锁定",
      "sideEffects": [
        "科技节点高亮"
      ]
    },
    {
      "from": "tech:available",
      "to": "tech:researching",
      "trigger": "startResearch",
      "condition": "科技点充足",
      "sideEffects": [
        "扣除科技点",
        "开始研究倒计时"
      ]
    },
    {
      "from": "tech:researching",
      "to": "tech:completed",
      "trigger": "researchComplete",
      "condition": "研究倒计时结束",
      "sideEffects": [
        "科技效果生效",
        "解锁后续科技"
      ]
    },
    {
      "from": "tech:researching",
      "to": "tech:available",
      "trigger": "cancelResearch",
      "condition": "玩家取消研究",
      "sideEffects": [
        "返还部分科技点"
      ]
    },
    {
      "from": "fusion-tech:locked",
      "to": "fusion-tech:available",
      "trigger": "unlockFusionTech",
      "condition": "双路径科技均已完成",
      "sideEffects": [
        "融合科技节点解锁"
      ]
    },
    {
      "from": "fusion-tech:available",
      "to": "fusion-tech:researching",
      "trigger": "startFusionResearch",
      "condition": "科技点充足",
      "sideEffects": [
        "扣除科技点"
      ]
    },
    {
      "from": "fusion-tech:researching",
      "to": "fusion-tech:completed",
      "trigger": "fusionResearchComplete",
      "condition": "研究完成",
      "sideEffects": [
        "融合科技效果生效"
      ]
    },
    {
      "from": "stage:locked",
      "to": "stage:available",
      "trigger": "unlockStage",
      "condition": "前置关卡已通关",
      "sideEffects": [
        "关卡解锁动画"
      ]
    },
    {
      "from": "stage:available",
      "to": "stage:cleared",
      "trigger": "clearStage",
      "condition": "战斗胜利(1-2星)",
      "sideEffects": [
        "发放通关奖励",
        "解锁下一关"
      ]
    },
    {
      "from": "stage:available",
      "to": "stage:threeStar",
      "trigger": "threeStarClear",
      "condition": "战斗胜利(3星) && 存活≥4 && 回合≤6",
      "sideEffects": [
        "发放三星奖励",
        "解锁扫荡功能"
      ]
    },
    {
      "from": "stage:cleared",
      "to": "stage:threeStar",
      "trigger": "improveStars",
      "condition": "重新挑战达到3星条件",
      "sideEffects": [
        "补发三星奖励差值"
      ]
    },
    {
      "from": "battle:init",
      "to": "battle:in-progress",
