    {"id": "st-hero-dispatched", "entity": "Hero", "state": "dispatched", "isInitial": false, "isFinal": false},

    {"id": "st-battle-prepare", "entity": "Battle", "state": "preparing", "isInitial": true, "isFinal": false},
