    {"id": "st-game-playing", "entity": "Game", "state": "playing", "isInitial": false, "isFinal": false},
    {"id": "st-game-paused", "entity": "Game", "state": "paused", "isInitial": false, "isFinal": false},
    {"id": "st-game-rebirth", "entity": "Game", "state": "rebirth", "isInitial": false, "isFinal": false},

    {"id": "st-bld-locked", "entity": "Building", "state": "locked", "isInitial": true, "isFinal": false},
    {"id": "st-bld-idle", "entity": "Building", "state": "idle", "isInitial": false, "isFinal": false},
    {"id": "st-bld-upgrading", "entity": "Building", "state": "upgrading", "isInitial": false, "isFinal": false},
    {"id": "st-bld-max", "entity": "Building", "state": "maxLevel", "isInitial": false, "isFinal": true},

    {"id": "st-hero-locked", "entity": "Hero", "state": "locked", "isInitial": true, "isFinal": false},
