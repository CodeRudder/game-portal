/** 所有武将 ID 列表 */
export const ALL_DIALOGUE_GENERAL_IDS = Object.keys(GENERAL_DIALOGUES);

// ═══════════════════════════════════════════════════════════════
// 对话系统类
// ═══════════════════════════════════════════════════════════════

/**
 * 武将对话系统
 *
 * 管理武将对话数据，根据场景和模式返回合适的对话内容。
 */
export class GeneralDialogueSystem {
  /** 对话数据 */
  private dialogues: Map<string, GeneralDialogueSet> = new Map();
  /** 对话历史（用于避免重复） */
  private history: Map<string, number> = new Map();

  constructor() {
    // 加载对话数据
    for (const [id, dialogue] of Object.entries(GENERAL_DIALOGUES)) {
      this.dialogues.set(id, dialogue);
    }
  }

  /**
   * 获取武将对话
   *
   * @param generalId - 武将 ID
   * @param scene - 对话场景
   * @param mode - 对话模式
   * @returns 对话结果
   */
  getDialogue(generalId: string, scene: DialogueScene, mode: DialogueMode = 'chat'): DialogueResult {
    const set = this.dialogues.get(generalId);
    if (!set) {
      return {
        text: '……',
        generalId,
        scene,
        mode,
      };
    }

    let pool: string[];

    if (mode === 'quest') {
      // 任务模式优先使用 quest 对话
      pool = set.quest;
    } else {
      // 闲聊模式根据场景选择
      switch (scene) {
        case 'battle':
          pool = set.battle;
          break;
        case 'recruit':
          pool = set.recruit;
          break;
        case 'idle':
        default:
          pool = set.idle;
          break;
      }
    }

    if (pool.length === 0) {
      return {
        text: '……',
        generalId,
        scene,
        mode,
      };
    }

    // 避免连续重复
    const key = `${generalId}_${scene}_${mode}`;
    const lastIndex = this.history.get(key) ?? -1;
    let index = lastIndex;
    if (pool.length > 1) {
      while (index === lastIndex) {
        index = Math.floor(Math.random() * pool.length);
      }
    } else {
      index = 0;
    }
    this.history.set(key, index);

    return {
      text: pool[index],
      generalId,
      scene,
      mode,
    };
  }

  /**
   * 获取武将所有对话集
   */
  getDialogueSet(generalId: string): GeneralDialogueSet | undefined {
    return this.dialogues.get(generalId);
  }

  /**
   * 获取指定场景的对话列表
   */
  getDialoguesByScene(generalId: string, scene: DialogueScene): string[] {
    const set = this.dialogues.get(generalId);
    if (!set) return [];
    return set[scene] ?? [];
  }

  /**
   * 获取任务对话
   */
  getQuestDialogue(generalId: string): string {
    const set = this.dialogues.get(generalId);
    if (!set || set.quest.length === 0) return '暂无任务。';
    return set.quest[Math.floor(Math.random() * set.quest.length)];
  }

  /**
   * 获取随机闲聊对话
   */
  getIdleChat(generalId: string): string {
    const set = this.dialogues.get(generalId);
    if (!set || set.idle.length === 0) return '……';
    return set.idle[Math.floor(Math.random() * set.idle.length)];
  }

  /**
   * 获取所有已注册的武将 ID
   */
  getRegisteredGeneralIds(): string[] {
    return Array.from(this.dialogues.keys());
  }

  /**
   * 检查武将是否有对话数据
   */
  hasDialogue(generalId: string): boolean {
    return this.dialogues.has(generalId);
  }

  /**
   * 获取武将名称
   */
  getGeneralName(generalId: string): string {
    const set = this.dialogues.get(generalId);
    return set?.generalName ?? '未知武将';
  }
}

/**
 * 创建全局对话系统实例
 */
export function createGeneralDialogueSystem(): GeneralDialogueSystem {
  return new GeneralDialogueSystem();
}
