/**
 * 武将对话系统 — 三国特色 NPC 对话
 *
 * 为12位三国武将提供丰富的对话内容，支持多种对话场景。
 * 对话根据游戏进度（场景类型）变化，分为"闲聊"和"任务"两种模式。
 *
 * @module games/three-kingdoms/GeneralDialogueSystem
 */

// ═══════════════════════════════════════════════════════════════
// 类型定义
// ═══════════════════════════════════════════════════════════════

/** 对话场景类型 */
export type DialogueScene = 'idle' | 'battle' | 'recruit';

/** 对话模式 */
export type DialogueMode = 'chat' | 'quest';

/** 单条对话 */
export interface DialogueLine {
  /** 对话文本 */
  text: string;
  /** 对话场景 */
  scene: DialogueScene;
  /** 对话模式 */
  mode: DialogueMode;
}

/** 武将对话集 */
export interface GeneralDialogueSet {
  /** 武将 ID */
  generalId: string;
  /** 武将名称 */
  generalName: string;
  /** 闲聊对话（idle 场景） */
  idle: string[];
  /** 战斗对话（battle 场景） */
  battle: string[];
  /** 招募对话（recruit 场景） */
  recruit: string[];
  /** 任务对话 */
  quest: string[];
}

/** 对话结果 */
export interface DialogueResult {
  /** 对话文本 */
  text: string;
  /** 武将 ID */
  generalId: string;
  /** 对话场景 */
  scene: DialogueScene;
  /** 对话模式 */
  mode: DialogueMode;
}

// ═══════════════════════════════════════════════════════════════
// 12 武将对话数据
