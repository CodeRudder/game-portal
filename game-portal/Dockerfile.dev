# ============================================
# Game Portal - 开发运行环境
# ============================================
# 用途：创建 Node.js 容器挂载项目目录，
#       通过 docker exec 远程执行编译和启动
# ============================================
FROM node:20-alpine

WORKDIR /app

# 安装基础工具
RUN apk add --no-cache curl bash

# 暴露 Vite dev server 端口
EXPOSE 3000

# 保持容器运行
CMD ["sleep", "infinity"]
